# ---------------------------------------------------------------------------
# Mission Control OS — example environment
# Copy to .env (root) and apps/api/.env:  cp env.example .env
# NEVER commit real secrets.
# ---------------------------------------------------------------------------

# App
APP_ENV=development
APP_NAME=Mission Control OS
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Database
# P0 default: zero-install SQLite. No Docker required.
DATABASE_URL=sqlite:///./mcos.db
# When Docker/Postgres is available, switch to:
# DATABASE_URL=postgresql+psycopg://mcos:mcos@localhost:5432/mcos
POSTGRES_USER=mcos
POSTGRES_PASSWORD=mcos
POSTGRES_DB=mcos

# Redis (optional in P0 — council runs synchronously)
REDIS_URL=redis://localhost:6379/0

# Auth P0 (dev stub)
DEV_AUTH_ENABLED=true
DEV_USER_EMAIL=george@example.local
DEV_ORG_NAME=Mission Control Dev

# Models — mock by default, no API keys needed
ENABLE_REAL_MODELS=false
DEFAULT_MODEL_PROVIDER=mock
GEORGE_PROVIDER=openai
GEORGE_MODEL=gpt-5.6-sol
CIPHER_PROVIDER=anthropic
CIPHER_MODEL=claude-fable-5
ARTY_PROVIDER=openai
ARTY_MODEL=gpt-5.6-sol-codex

# API keys — leave blank for mock mode; do not commit real values
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Observability (P1)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Security
SECRET_KEY=change-me-in-dev
CORS_ORIGINS=http://localhost:3000

# Frontend (Next.js public)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
